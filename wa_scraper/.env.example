# ── WhatsApp scraper configuration ─────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Name of the WhatsApp group to watch (exact match, case-sensitive)
WA_GROUP_NAME=Workouts

# How many recent messages to scrape on first startup (0 = skip backfill)
INITIAL_SCRAPE_LIMIT=100

# Directory where downloaded images are saved.
# Must be accessible to the Flask app too (same machine).
# Defaults to wa_scraper/media/ relative to this file.
# WA_MEDIA_DIR=C:/Users/jacco/OneDrive/Desktop/usdrowing/wa_scraper/media

# ── MySQL connection (same DB as the Flask app) ─────────────────────────────
DB_HOST=dbaas-db-3926028-do-user-21648043-0.g.db.ondigitalocean.com
DB_PORT=25060
DB_USER=doadmin
DB_PASSWORD=your_password_here
DB_NAME=credentialing
DB_SSL=true
